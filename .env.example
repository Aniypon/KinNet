# --- Django ---
DJANGO_DEBUG=1
# DJANGO_SECRET_KEY — секрет Django: подписывает сессионные cookie, CSRF-токены,
# токены сброса пароля и любые вызовы signing.dumps/loads. Утечка = подделка
# сессий и CSRF в обход. В проде ОБЯЗАТЕЛЬНО заменить на случайную строку
# >=50 символов. Сгенерировать:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_ALLOWED_HOSTS=*
SITE_URL=http://localhost:8080

# --- Database / Redis ---
# Local dev (without docker) falls back to SQLite if DATABASE_URL is unset.
DATABASE_URL=postgres://kinnet:kinnet@db:5432/kinnet
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Nginx ---
NGINX_PORT=8080
