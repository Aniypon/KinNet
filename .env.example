# --- Django ---
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_ALLOWED_HOSTS=*
SITE_URL=http://localhost:8080

# --- Database / Redis ---
# Local dev (without docker) falls back to SQLite if DATABASE_URL is unset.
DATABASE_URL=postgres://kinnet:kinnet@db:5432/kinnet
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# When set, the bot runs in webhook mode; otherwise it falls back to polling.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# --- Nginx ---
NGINX_PORT=8080
